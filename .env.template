# ╔══════════════════════════════════════════════════════════════╗
# ║  gireng — Environment Configuration                        ║
# ║  Copy this file:  cp .env.template .env                    ║
# ║  Then fill in your API key below and run docker compose up ║
# ╚══════════════════════════════════════════════════════════════╝

# ── LLM API Key (REQUIRED) ──────────────────────────────────────
# Get your key from your LLM provider (DeepSeek, OpenAI-compatible, etc.)
#
# Default DeepSeek configuration:
# - API format: OpenAI-compatible Chat Completions
# - Endpoint: https://api.deepseek.com
# - Model: deepseek-v4-pro
# - Thinking mode is enabled by default; set LLM_THINKING_MODE=disabled to turn it off.
LLM_PROVIDER=openai
LLM_API_KEY=<your-deepseek-api-key>
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-pro
LLM_REASONING_EFFORT=high
LLM_THINKING_MODE=enabled

# Provider-specific aliases are also supported. You can switch providers
# without code changes by changing the env values above or these aliases.
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI-compatible override example:
# OPENAI_API_KEY=<your-openai-compatible-api-key>
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Anthropic-compatible override example:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=<your-anthropic-compatible-api-key>
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_MODEL=deepseek-v4-pro

# ── Public Host Placeholder (used by UI/API/Langfuse URLs) ──────
# Change HOST once and all browser-facing URLs follow it.
HOST=localhost
API_PORT=8080
UI_PORT=4173
LANGFUSE_PORT=3100

# ── CORS Origins ────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend API.
# CORS_ORIGINS=http://localhost:4173,http://localhost:3000

# ── Resource Limits ─────────────────────────────────────────────
# Max uploaded binary size in bytes (default: 209715200 = 200 MB)
MAX_UPLOAD_BYTES=209715200
DEFAULT_USER_QUOTA=10

# ── LLM Retry Configuration ─────────────────────────────────────
LLM_TIMEOUT=1200
LLM_MAX_RETRIES=2

# ── Memory / Semantic Search ────────────────────────────────────
# Directory for local memory storage and embedding model name.
# MEMORY_DIR=./memory
# EMBEDDING_MODEL=text-embedding-3-small

# Optional explicit URL overrides (leave commented in most setups)
# VITE_API_BASE_URL=http://localhost:8080
# VITE_WS_URL=ws://localhost:8080/stream
# LANGFUSE_URL=http://localhost:3100

# ── Ghidra Runner Image ─────────────────────────────────────────
RUNNER_IMAGE=danilid/ireng-runner:2.0.1

# ── Function Prioritization Weights ─────────────────────────────
# score = alpha * norm(xrefs) + beta * norm(size)
FUNCTION_PRIORITY_ALPHA=0.7
FUNCTION_PRIORITY_BETA=0.3

# ── Optional Dynamic Analyzer (Qiling) ──────────────────────────
# Qiling runs inside its own container and adds runtime behavior traces.
ENABLE_QILING=true
QILING_TIMEOUT=60

# ── Radare2 Resource Limits ─────────────────────────────────────
# Cap Radare2 so it does not consume excessive host CPU/RAM.
R2_CPU_LIMIT=2.0
R2_MEM_LIMIT=2g
R2_MEMSWAP_LIMIT=2g
# Per-command timeout (seconds) and hard cap for full R2 pipeline.
R2_TIMEOUT=60
R2_PIPELINE_TIMEOUT=420

# ── PostgreSQL (defaults are fine for local dev) ────────────────
# POSTGRES_PASSWORD=gireng_secret

# ── Langfuse Tracing (optional — auto-configured in docker) ────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://langfuse:3000
# LANGFUSE_NEXTAUTH_SECRET=changeme-langfuse-secret
# LANGFUSE_SALT=changeme-langfuse-salt
