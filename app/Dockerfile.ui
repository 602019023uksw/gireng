FROM node:20-alpine

WORKDIR /app

# VITE_API_BASE_URL is intentionally left EMPTY so the frontend uses relative
# URLs (e.g. /api/...) which the Vite preview proxy then forwards server-side.
# This eliminates all browser-level CORS issues.
ARG VITE_API_BASE_URL=
ARG VITE_WS_URL=
ARG VITE_APP_NAME=IrengSec

# BACKEND_INTERNAL_URL is used by vite.config.ts proxy at RUNTIME (preview).
# It points to the backend container from inside Docker networking.
ARG BACKEND_INTERNAL_URL=http://agent:8080
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL \
    VITE_WS_URL=$VITE_WS_URL \
    VITE_APP_NAME=$VITE_APP_NAME \
    BACKEND_INTERNAL_URL=$BACKEND_INTERNAL_URL

COPY app/package.json app/package-lock.json ./
RUN npm ci

COPY app/ ./

RUN npm run build

EXPOSE 4173

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "4173"]
